{
    "name": "marcoconsiglio/modular-arithmetic",
    "description": "A PHP libarary to support modular arithmetic, aka clock arithmetic.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "MarcoConsiglio\\ModularArithmetic\\": "src/",
            "MarcoConsiglio\\ModularArithmetic\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Marco Consiglio",
            "email": "mrccnsgl@gmail.com"
        }
    ],
    "minimum-stability": "stable",
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "fakerphp/faker": "^1.24",
        "rector/rector": "^2.3",
        "marcoconsiglio/faker-php-number-helpers": "^4"
    },
    "require": {
        "php": "^8.4",
        "marcoconsiglio/bcmath-extended": "^2.5"
    }
}
